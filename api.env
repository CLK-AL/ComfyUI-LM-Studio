# Environment for the api/ monorepo. Loaded by:
#   • Python:   `python-dotenv` (auto-picked by pytest via conftest.py)
#   • Kotlin:   `io.github.cdimascio:dotenv-kotlin` (loaded by APIMock.kt)
#
# All repo-relative paths are anchored at API_ROOT (the directory that
# ships `api.env` itself). Absolute tool paths (JBANG_HOME, …) default
# to the SDKMAN layout; override with your own install if you don't use
# SDKMAN.

# --- Repo anchors (repo-root relative — never hard-code an absolute) --
API_ROOT=api
API_SRC=api/src
COMMON_MAIN=api/src/commonMain/kotlin/al/clk/api
JBANG_MAIN=api/src/jbangMain/kotlin/al/clk/api
PY_MAIN=src/pyMain/py
PY_TEST=src/pyTest/py
PROTO_ROOT=api/src/proto/al/clk/api

# --- Tool homes (override as needed) ---------------------------------
JBANG_HOME=${HOME}/.sdkman/candidates/jbang/current
JAVA_HOME=${HOME}/.sdkman/candidates/java/current
KOTLIN_HOME=${HOME}/.sdkman/candidates/kotlin/current
GRADLE_HOME=${HOME}/.sdkman/candidates/gradle/current
PYTHON_HOME=venv

# --- Mock server defaults (picked up by conftest + APIMock.kt) -------
WIREMOCK_HOST=127.0.0.1
WIREMOCK_PORT=8089
ASYNCAPI_PORT=8090
MCP_PORT=8091
RSOCKET_PORT=8094

# --- OpenAPI spec (LM Studio primary + fallback mirror) --------------
OPENAPI_SPEC_URL=https://lmstudio.ai/docs/openapi.yaml
OPENAPI_SPEC_FALLBACK=https://docs.lmstudio.ai/openapi.yaml
OPENAPI_SPEC_LOCAL=api/openapi/spec/lm-studio.yaml
